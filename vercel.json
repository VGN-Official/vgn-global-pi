{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/validation-key.txt",
      "headers": {
        "Content-Type": "text/plain; charset=utf-8",
        "Cache-Control": "no-store, no-cache, must-revalidate",
        "Access-Control-Allow-Origin": "*"
      },
      "dest": "/validation-key.txt"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}