{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/validation-key.txt", "destination": "/validation-key.txt" }
  ],
  "headers": [
    {
      "source": "/validation-key.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}